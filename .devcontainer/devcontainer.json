{
  "name": "Analytics Dev Container",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace/analytics",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "ms-azuretools.vscode-docker",
        "ms-vscode.live-server",
        "tamasfe.even-better-toml"
      ]
    }
  },
  "remoteUser": "node",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },
  "postCreateCommand": "sudo npm install -g @google/gemini-cli && for dir in shared server client docs monitor-agent; do if [ -d \"$dir\" ] && [ -f \"$dir/package.json\" ]; then echo \"Installing dependencies in $dir...\" && (cd \"$dir\" && npm install); fi; done",
  "forwardPorts": [3001, 3002, 5432, 8123, 6379]
}
